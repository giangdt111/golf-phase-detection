# Device
DEVICE=cuda:0
SEG_DEVICE=cuda:0

# input/output Paths
VIDEO_PATH=video_raw/IMG_6850_1.MOV
OUTPUT_ROOT=output

# MODEL
POSE2D_CONFIG=mmpose-main/configs/body_2d_keypoint/topdown_heatmap/coco/td-hm_hrnet-w48_8xb32-210e_coco-256x192.py
POSE2D_WEIGHTS=model/hrnet_w48_coco_256x192-b9e0b3ab_20200708.pth
SEG_MODEL=model/golf_segment.pt
PERSON_DET_MODEL=model/yolov8n_person_detection.pt

# Inference knobs
# STRIDE: sample every Nth frame to speed up; 1 = use all frames
STRIDE=1
# MAX_FRAMES: limit total processed frames; 0 = no limit
MAX_FRAMES=0
# EVENT_MODE: rule | rule9 (rule9 uses club segmentation cues)
EVENT_MODE=rule9
# OVERLAY_SCORE_THR: min keypoint score to draw on overlay
OVERLAY_SCORE_THR=0.2
# SEG_IMGSZ: YOLOv8 seg inference size
SEG_IMGSZ=960
# SEG_CONF: YOLOv8 seg confidence threshold
SEG_CONF=0.25
# SEG_IOU: YOLOv8 seg IoU threshold
SEG_IOU=0.7
# SEG_ALPHA: mask opacity for overlay (0=transparent,1=solid)
SEG_ALPHA=0.45
# SEG_DISABLE: true to skip segmentation entirely
SEG_DISABLE=false
# DET_DEBUG: true to log first few detector bbox results
DET_DEBUG=false
# PERSON_DET_CONF: YOLOv8 person detector confidence
PERSON_DET_CONF=0.25
# PERSON_DET_IOU: YOLOv8 person detector IoU
PERSON_DET_IOU=0.7
# PERSON_DET_IMGSZ: YOLOv8 person detector imgsz
PERSON_DET_IMGSZ=640
